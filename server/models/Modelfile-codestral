    double valueMeters = 5.0 * 0.001;
    TopSolidHost.Parameters.SetRealParameterValue(param, valueMeters);
    TopSolidHost.Application.EndModification(true, true);
    PdmObjectId pdm = TopSolidHost.Documents.GetPdmObject(docId);
    TopSolidHost.Pdm.Save(pdm, true);
    return "OK: Epaisseur = 5mm";
} catch (Exception ex) {
    TopSolidHost.Application.EndModification(false, false);
    return "ERROR: " + ex.Message;
}
```

